{
  "name": "temp-mail",
  "private": true,
  "workspaces": ["frontend", "worker"],
  "scripts": {
    "dev": "concurrently -n worker,frontend -c blue,green \"npm run dev:worker\" \"npm run dev:frontend\"",
    "dev:frontend": "npm -w frontend run dev",
    "dev:worker": "npm -w worker run dev",
    "build": "npm -w frontend run build",
    "deploy:worker": "npm -w worker run deploy",
    "deploy:frontend": "npm -w frontend run deploy",
    "db:migrate": "wrangler d1 execute temp-mail-db --file=worker/schema.sql",
    "db:migrate:local": "wrangler d1 execute temp-mail-db --file=worker/schema.sql --local"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
